rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── USERS ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['nickname', 'clicked'])
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() >= 2
        && request.resource.data.clicked is list;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && (!('age' in request.resource.data) || (request.resource.data.age is number && request.resource.data.age >= 18))
        && (!('ageMin' in request.resource.data) || (request.resource.data.ageMin is number && request.resource.data.ageMin >= 18))
        && (!('ageMax' in request.resource.data) || (request.resource.data.ageMax is number && request.resource.data.ageMax >= 18));
      allow delete: if false;
    }

    // ─── STATEMENTS ──────────────────────────────────────────────────────────
    match /statements/{statementId} {
      allow read: if request.auth != null;
      allow create: if false; // statements are created only via the createStatement Cloud Function (admin SDK)
      allow update: if request.auth != null && (
        resource.data.authorId == request.auth.uid
        || (request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['clicks', 'reports']))
      );
      allow delete: if request.auth != null && (
        resource.data.authorId == request.auth.uid
        || request.auth.uid == 'ezPSAlWRjZbqGGTIzWK2LRqLgR12'
      );
    }

    // ─── STATEMENT USERS (инвертированный индекс) ────────────────────────────
    match /statement_users/{statementId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── CHATS ───────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      function isChatMember() {
        let parts = chatId.split('_');
        return request.auth.uid == parts[0] || request.auth.uid == parts[1];
      }
      match /messages/{messageId} {
        allow read: if request.auth != null && isChatMember();
        allow create: if request.auth != null
          && isChatMember()
          && request.resource.data.from == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0;
        allow update, delete: if false;
      }
      match /meta/{metaId} {
        allow read: if request.auth != null && isChatMember();
        allow write: if request.auth != null && isChatMember();
      }
    }

    // ─── USER CHATS (список активных чатов) ──────────────────────────────────
    match /user_chats/{userId} {
      match /chats/{chatId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

  }
}
